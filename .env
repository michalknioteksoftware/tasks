###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_this_secret_in_production
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://tasks:tasks_secret@db:5432/tasks?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> app password config (used for user password hashing, override in .env.local for production) ###
PASSWORD_SALT='xK9#mP2$vL7@nQ4!wR8&jF3'
PASSWORD_ALGO=sha256
###< app password config ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
