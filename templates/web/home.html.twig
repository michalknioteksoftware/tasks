{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
    {% form_theme login_form 'bootstrap_5_layout.html.twig' %}

    <div class="container">
        <h1 class="mb-3">Welcome</h1>
        <p>This is the frontend web part of the application.</p>
        <p>API is available at <a href="{{ path('api_health') }}">/api/health</a></p>

        <hr class="my-4">

        {% if is_logged_in %}
            <p class="mb-2">You are logged in.</p>
            {% if is_admin %}
                <p><strong>Admin:</strong> you have administrator privileges.</p>
            {% else %}
                <p><strong>User:</strong> you are logged in as a regular user.</p>
            {% endif %}

            <form method="post" action="{{ path('web_logout') }}" class="mt-3">
                <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
            </form>
        {% else %}
            {% if login_error %}
                <div class="alert alert-danger" role="alert">
                    {{ login_error }}
                </div>
            {% endif %}

            <div class="mt-3">
                {{ form_start(login_form) }}
                    {{ form_row(login_form.identifier) }}
                    {{ form_row(login_form.password) }}
                    {{ form_row(login_form.login, {'attr': {'class': 'btn btn-primary'}}) }}
                {{ form_end(login_form) }}
            </div>
        {% endif %}
    </div>
{% endblock %}
