{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
    {% form_theme login_form 'bootstrap_5_layout.html.twig' %}

    <div class="container">
        <h1 class="mb-3">Welcome</h1>
        <p>This is the frontend web part of the application.</p>
        <p>API is available at <a href="{{ path('api_health') }}">/api/health</a></p>
        <p><a href="{{ path('web_users_from_api') }}">Users from API</a> (list from JSONPlaceholder)</p>

        <hr class="my-4">

        {% if is_logged_in %}
            <p class="mb-2">You are logged in.</p>
            {% if is_admin %}
                <p><strong>Admin:</strong> you have administrator privileges.</p>
                <p class="mt-2">
                    <a href="{{ path('web_admin_tasks') }}" class="btn btn-primary btn-sm">List all users' tasks</a>
                </p>
            {% else %}
                <p><strong>User:</strong> you are logged in as a regular user.</p>
            {% endif %}

            {% if user %}
                <div class="card my-3">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Current user</h5>
                        <p class="mb-1"><strong>Name:</strong> {{ user.name }}</p>
                        <p class="mb-1"><strong>Username:</strong> {{ user.username }}</p>
                        <p class="mb-1"><strong>Email:</strong> {{ user.email }}</p>
                        <p class="mb-1">
                            <strong>Created at:</strong>
                            {{ user.createdAt|date('Y-m-d H:i') }}
                        </p>
                        {% if user.address %}
                            <p class="mb-1">
                                <strong>Address:</strong>
                                {{ user.address.street }},
                                {{ user.address.city }}
                                {% if user.address.zipcode %} ({{ user.address.zipcode }}){% endif %}
                            </p>
                        {% endif %}
                        {% if user.company %}
                            <p class="mb-0">
                                <strong>Company:</strong> {{ user.company.name }}
                                {% if user.company.catchPhrase %}- {{ user.company.catchPhrase }}{% endif %}
                            </p>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            <form method="post" action="{{ path('web_logout') }}" class="mt-3">
                <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
            </form>

            <p class="mt-3">
                <a href="{{ path('web_tasks') }}" class="btn btn-primary btn-sm">
                    View your tasks
                </a>
            </p>
        {% else %}
            {% if login_error %}
                <div class="alert alert-danger" role="alert">
                    {{ login_error }}
                </div>
            {% endif %}

            <div class="alert alert-warning mt-3" role="alert">
                <strong>Sample credentials:</strong><br>
                admin@example.com / Password1<br>
                Sincere@april.biz / ChangeMe<br>
                otherEmailFromJsonPlaceholder / ChangeMe
            </div>

            <div class="mt-3">
                {{ form_start(login_form) }}
                    {{ form_row(login_form.identifier) }}
                    {{ form_row(login_form.password) }}
                    {{ form_row(login_form.login, {'attr': {'class': 'btn btn-primary'}}) }}
                {{ form_end(login_form) }}
            </div>
        {% endif %}
    </div>
{% endblock %}
